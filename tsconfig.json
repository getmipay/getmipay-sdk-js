{
  "compilerOptions": {
    "target"            : "ES2018",
    "module"            : "commonjs",
    "lib"               : ["ES2018"],
    "outDir"            : "./dist",
    "rootDir"           : "./src",
    "declaration"       : true,
    "declarationDir"    : "./types",
    "strict"            : true,
    "esModuleInterop"   : true,
    "skipLibCheck"      : true,
    "forceConsistentCasingInFileNames": true
  },
  "include" : ["types/**/*"],
  "exclude" : ["node_modules", "tests", "examples", "dist"]
}